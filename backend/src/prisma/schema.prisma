// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// users.id mirrors auth.users.id (Supabase Auth) — no @default, the app
// assigns it from the Supabase Auth user id at registration time.
// role/status are VARCHAR (not native Postgres enum) per docs/03-Database
// Schema.md convention used across the whole schema; allowed values are
// validated at the Zod layer, not enforced by a DB enum type.
model User {
  id              String    @id @db.Uuid
  name            String    @db.VarChar(255)
  email           String    @unique @db.VarChar(255)
  role            String    @db.VarChar(20)
  status          String    @db.VarChar(30)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamp(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  profile                       UserProfile?
  userSkills                    UserSkill[]
  experiences                   Experience[]
  portfolioLinks                PortfolioLink[]
  projectsAsUmkm                Project[]             @relation("ProjectUmkm")
  projectsAsSenior              Project[]             @relation("ProjectSenior")
  seniorApplications            SeniorApplication[]
  projectApplications           ProjectApplication[]
  projectMemberships            ProjectMember[]
  discussionMembers             DiscussionMember[]
  discussionMessages            DiscussionMessage[]
  submittedDeliverables         Deliverable[]
  contributionReportsAsBeginner ContributionReport[]  @relation("ContributionReportBeginner")
  contributionReportsReviewed   ContributionReport[]  @relation("ContributionReportReviewer")
  artifactsAsBeginner           Artifact[]            @relation("ArtifactBeginner")
  artifactsAsSenior             Artifact[]            @relation("ArtifactSenior")
  artifactVersionsGenerated     ArtifactVersion[]
  reviewsGiven                  Review[]              @relation("ReviewReviewer")
  reviewsReceived               Review[]              @relation("ReviewReviewee")
  notifications                 Notification[]
  verificationRequests          VerificationRequest[] @relation("VerificationRequestUser")
  verificationRequestsReviewed  VerificationRequest[] @relation("VerificationRequestReviewer")
  auditLogs                     AuditLog[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model UserProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  phone             String?  @db.VarChar(30)
  photo             String?  @db.VarChar(1000)
  headline          String?  @db.VarChar(255)
  bio               String?
  linkedinUrl       String?  @map("linkedin_url") @db.VarChar(1000)
  verificationNotes String?  @map("verification_notes")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// status: PENDING | APPROVED | REJECTED — custom (non-system) skills need
// Admin approval before becoming usable master skills, per
// docs/06-RBAC_and_Business_Rules.md "Custom Skills" constraint.
model Skill {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(150)
  category  String   @db.VarChar(100)
  status    String   @db.VarChar(20)
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  userSkills         UserSkill[]
  roleSkills         RoleSkill[]
  contributionSkills ContributionSkill[]

  @@index([status])
  @@map("skills")
}

// level: BEGINNER | INTERMEDIATE | ADVANCED
model UserSkill {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  skillId   String   @map("skill_id") @db.Uuid
  level     String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("user_skills")
}

model Experience {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  title        String    @db.VarChar(255)
  organization String    @db.VarChar(255)
  description  String?
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

// type: GITHUB | FIGMA | BEHANCE | LINKEDIN | OTHER
model PortfolioLink {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(255)
  url       String   @db.VarChar(1000)
  type      String   @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portfolio_links")
}

model ProjectCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  projects Project[]

  @@map("project_categories")
}

// status: DRAFT | PENDING_REVIEW | PUBLISHED | RECRUITING | ACTIVE | OVERDUE
// | COMPLETED | CANCELLED. Soft delete via deletedAt (only table in the
// schema that uses soft deletes, per docs/03-Database Schema.md).
model Project {
  id                   String    @id @default(uuid()) @db.Uuid
  umkmId               String    @map("umkm_id") @db.Uuid
  seniorId             String?   @map("senior_id") @db.Uuid
  categoryId           String    @map("category_id") @db.Uuid
  title                String    @db.VarChar(255)
  description          String
  expectedDeliverables String    @map("expected_deliverables")
  startDate            DateTime  @map("start_date") @db.Date
  deadline             DateTime  @db.Date
  completedAt          DateTime? @map("completed_at") @db.Timestamp(6)
  status               String    @db.VarChar(30)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt            DateTime? @map("deleted_at") @db.Timestamp(6)

  umkm     User            @relation("ProjectUmkm", fields: [umkmId], references: [id])
  senior   User?           @relation("ProjectSenior", fields: [seniorId], references: [id])
  category ProjectCategory @relation(fields: [categoryId], references: [id])

  milestones          Milestone[]
  projectRoles        ProjectRole[]
  seniorApplications  SeniorApplication[]
  projectApplications ProjectApplication[]
  projectMembers      ProjectMember[]
  discussions         Discussion[]
  deliverables        Deliverable[]
  contributionReports ContributionReport[]
  artifacts           Artifact[]
  reviews             Review[]

  @@index([status])
  @@index([deadline])
  @@index([umkmId])
  @@index([seniorId])
  @@map("projects")
}

// status: PENDING | IN_PROGRESS | COMPLETED
model Milestone {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?
  dueDate     DateTime @map("due_date") @db.Date
  status      String   @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

// capacity > 0 enforced via raw-SQL CHECK constraint in the migration
// (Prisma schema has no native @@check attribute, confirmed via Context7).
model ProjectRole {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  roleName     String   @map("role_name") @db.VarChar(100)
  capacity     Int
  requirements String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleSkills          RoleSkill[]
  projectApplications ProjectApplication[]
  projectMembers      ProjectMember[]

  @@map("project_roles")
}

model RoleSkill {
  id            String   @id @default(uuid()) @db.Uuid
  projectRoleId String   @map("project_role_id") @db.Uuid
  skillId       String   @map("skill_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  projectRole ProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)
  skill       Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectRoleId, skillId])
  @@map("role_skills")
}

// status: PENDING | ACCEPTED | REJECTED | WITHDRAWN
model SeniorApplication {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  seniorId  String   @map("senior_id") @db.Uuid
  message   String?
  status    String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  senior  User    @relation(fields: [seniorId], references: [id], onDelete: Cascade)

  @@map("senior_applications")
}

// status: PENDING | ACCEPTED | REJECTED | WITHDRAWN
model ProjectApplication {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  projectRoleId String   @map("project_role_id") @db.Uuid
  beginnerId    String   @map("beginner_id") @db.Uuid
  motivation    String?
  status        String   @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectRole ProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)
  beginner    User        @relation(fields: [beginnerId], references: [id], onDelete: Cascade)

  @@map("project_applications")
}

// status: ACTIVE | REMOVED | WITHDRAWN | COMPLETED
model ProjectMember {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  projectRoleId String   @map("project_role_id") @db.Uuid
  status        String   @db.VarChar(20)
  joinedAt      DateTime @map("joined_at") @db.Timestamp(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectRole ProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)

  @@map("project_members")
}

// type: GROUP | DIRECT — project_id is null for DIRECT (1:1) discussions.
model Discussion {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  type      String   @db.VarChar(20)
  // Phase 12 (Discussion Forum Upgrade): forum metadata for GROUP discussions;
  // null for DIRECT chats. category allowed values validated at the Zod layer
  // (ANNOUNCEMENT|QUESTION|IDEA|BLOCKER|MENTOR_REVIEW|UPDATE).
  title     String?  @db.VarChar(255)
  category  String?  @db.VarChar(30)
  isPinned  Boolean  @default(false) @map("is_pinned")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  members  DiscussionMember[]
  messages DiscussionMessage[]

  @@map("discussions")
}

model DiscussionMember {
  id           String   @id @default(uuid()) @db.Uuid
  discussionId String   @map("discussion_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
  @@map("discussion_members")
}

// Business Rule: discussion attachments are not supported in MVP.
model DiscussionMessage {
  id           String   @id @default(uuid()) @db.Uuid
  discussionId String   @map("discussion_id") @db.Uuid
  senderId     String   @map("sender_id") @db.Uuid
  message      String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  sender     User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("discussion_messages")
}

// status: DRAFT | SUBMITTED | REVISION_REQUESTED | APPROVED
model Deliverable {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  submittedBy String   @map("submitted_by") @db.Uuid
  title       String   @db.VarChar(255)
  description String?
  status      String   @db.VarChar(30)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submitter User    @relation(fields: [submittedBy], references: [id], onDelete: Cascade)

  evidences DeliverableEvidence[]

  @@map("deliverables")
}

// type: LINK | FILE — url is set for LINK, filePath is set for FILE.
model DeliverableEvidence {
  id            String   @id @default(uuid()) @db.Uuid
  deliverableId String   @map("deliverable_id") @db.Uuid
  type          String   @db.VarChar(20)
  url           String?  @db.VarChar(1000)
  filePath      String?  @map("file_path") @db.VarChar(1000)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  @@map("deliverable_evidences")
}

// status: PENDING | APPROVED
// reviewedBy is nullable even though docs/03-Database Schema.md doesn't mark
// it "NULL" explicitly — docs/04-API Specification.md confirms reports are
// created with status PENDING and reviewed/approved later via a separate
// endpoint, so no reviewer exists yet at creation time. See decisions.md.
model ContributionReport {
  id                  String   @id @default(uuid()) @db.Uuid
  projectId           String   @map("project_id") @db.Uuid
  beginnerId          String   @map("beginner_id") @db.Uuid
  contributionSummary String   @map("contribution_summary")
  status              String   @db.VarChar(20)
  reviewedBy          String?  @map("reviewed_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  beginner User    @relation("ContributionReportBeginner", fields: [beginnerId], references: [id])
  reviewer User?   @relation("ContributionReportReviewer", fields: [reviewedBy], references: [id])

  contributionSkills ContributionSkill[]

  @@map("contribution_reports")
}

model ContributionSkill {
  id                   String   @id @default(uuid()) @db.Uuid
  contributionReportId String   @map("contribution_report_id") @db.Uuid
  skillId              String   @map("skill_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  contributionReport ContributionReport @relation(fields: [contributionReportId], references: [id], onDelete: Cascade)
  skill              Skill              @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([contributionReportId, skillId])
  @@map("contribution_skills")
}

// artifactCode format: EDN-2026-000001
model Artifact {
  id              String   @id @default(uuid()) @db.Uuid
  artifactCode    String   @unique @map("artifact_code") @db.VarChar(50)
  projectId       String   @map("project_id") @db.Uuid
  beginnerId      String   @map("beginner_id") @db.Uuid
  seniorId        String   @map("senior_id") @db.Uuid
  verificationUrl String   @map("verification_url") @db.VarChar(1000)
  currentVersion  Int      @map("current_version")
  issuedAt        DateTime @map("issued_at") @db.Timestamp(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  beginner User    @relation("ArtifactBeginner", fields: [beginnerId], references: [id])
  senior   User    @relation("ArtifactSenior", fields: [seniorId], references: [id])

  versions ArtifactVersion[]

  @@map("artifacts")
}

// Business Rule: regeneration does not delete previous versions — no
// updatedAt field, matching docs/03-Database Schema.md (immutable history).
model ArtifactVersion {
  id          String   @id @default(uuid()) @db.Uuid
  artifactId  String   @map("artifact_id") @db.Uuid
  version     Int
  pdfPath     String   @map("pdf_path") @db.VarChar(1000)
  generatedBy String   @map("generated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  artifact  Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  generator User     @relation(fields: [generatedBy], references: [id])

  @@map("artifact_versions")
}

// type: SENIOR_TO_BEGINNER | UMKM_TO_BEGINNER | UMKM_TO_SENIOR
// rating BETWEEN 1 AND 5 enforced via raw-SQL CHECK constraint in the
// migration (Prisma schema has no native @@check attribute).
model Review {
  id         String    @id @default(uuid()) @db.Uuid
  projectId  String    @map("project_id") @db.Uuid
  reviewerId String    @map("reviewer_id") @db.Uuid
  revieweeId String    @map("reviewee_id") @db.Uuid
  rating     Int
  comment    String?
  type       String    @db.VarChar(50)
  isEdited   Boolean   @default(false) @map("is_edited")
  editedAt   DateTime? @map("edited_at") @db.Timestamp(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  reviewee User    @relation("ReviewReviewee", fields: [revieweeId], references: [id])

  @@map("reviews")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(30)
  title     String   @db.VarChar(255)
  message   String
  actionUrl String?  @map("action_url") @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// status: PENDING | APPROVED | REJECTED
// reviewedBy nullable for the same reason as ContributionReport.reviewedBy
// above — created PENDING, reviewed later (see docs/04-API Specification.md).
model VerificationRequest {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  status     String   @db.VarChar(20)
  notes      String?
  reviewedBy String?  @map("reviewed_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user     User  @relation("VerificationRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("VerificationRequestReviewer", fields: [reviewedBy], references: [id])

  @@map("verification_requests")
}

// No updatedAt — audit log entries are append-only / immutable.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(255)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.Uuid
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@map("audit_logs")
}
