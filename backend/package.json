{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "EduNomad backend API - Express.js + TypeScript + Prisma",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "morgan": "^1.11.0",
    "pdfkit": "^0.19.1",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "comment_overrides": "Pins @types/express-serve-static-core so req.params.id types as string (not string|string[]). Mirrors the root package.json override — needed here too because the Docker build (context = backend/) runs a standalone npm install without the workspace root.",
  "overrides": {
    "@types/express-serve-static-core": "5.0.7"
  }
}
